{
  "manifest_version": 3,
  "name": "YouTube Summary → ChatGPT",
  "version": "2.1",
  "description": "Extract YouTube transcript and summarize with ChatGPT. Works in Chrome, Brave, Firefox.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.youtube.com/*",
    "https://chatgpt.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["chatgpt-inject.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["relay.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
